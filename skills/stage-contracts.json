        {
          "question_id": "init.privacy_boundary",
          "category": "privacy",
          "prompt": "哪些内容属于客户隐私边界，不得进入产出？",
          "required": true,
          "assumption_allowed": true,
          "evidence_required": false,
          "trigger": "missing_privacy_boundary"
        },
        {
          "question_id": "init.customer_visible_forbidden",
          "category": "safety",
          "prompt": "是否存在客户可见禁词或禁用主张清单？",
          "required": false,
          "assumption_allowed": true,
          "evidence_required": false,
          "trigger": "missing_forbidden_terms"
