      ],
      "outputs": [
        {
          "artifact_type": "project_metadata",
          "path_pattern": "deck_project.json",
          "required": true,
          "schema_version": "deck_master_project.v1",
          "validator": "validate_deck_project"
        },
        {
          "artifact_type": "material_inventory",
          "path_pattern": "material_inventory.json",
          "required": true,
          "schema_version": "deck_master_material_inventory.v1",
          "validator": "validate_material_inventory"
        },
        {
          "artifact_type": "workspace_policy",
          "path_pattern": "workspace_policy.json",
          "required": true,
          "schema_version": "deck_master_workspace_policy.v1",
          "validator": "validate_workspace_policy"
        }
      ],
      "exit_criteria": {
        "required_artifacts": ["deck_project.json", "material_inventory.json", "workspace_policy.json"],
        "required_decisions": ["init.scan_scope", "init.privacy_boundary"],
        "validators": ["material_inventory_complete", "workspace_policy_fresh"],
        "required_capabilities": []
      },
      "transition_policy": {
        "next_stage": "deck-brief",
        "mode": "automatic",
        "approval_required": false,
        "preauthorizable": true,
        "non_bypassable": false
