      "forcing_questions": [
        {
          "question_id": "init.scan_scope",
          "category": "scope",
          "prompt": "本轮要扫描和纳入的材料范围是什么？",
          "required": true,
          "assumption_allowed": false,
          "evidence_required": false,
          "trigger": "missing_scan_scope"
