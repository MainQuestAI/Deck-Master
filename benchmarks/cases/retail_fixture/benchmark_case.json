    "context_to_approved_queue_minutes": 120,
    "page_acceptance_rate_min": 0.5,
    "reuse_adapt_rate_min": 0.3,
    "p0_count_max": 0,
    "evidence_gap_visible": true,
    "quality_gate_required": true
  },
  "scoring": {
    "weights": {
      "efficiency": 0.35,
      "page_acceptance": 0.2,
      "evidence_readiness": 0.15,
      "asset_reuse": 0.15,
      "quality_governance": 0.15
    }
  }
}

