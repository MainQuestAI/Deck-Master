{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/stage-contract.v1.schema.json",
  "title": "Deck Stage Contract v1",
  "type": "object",
  "required": [
    "schema_version",
    "stage_id",
    "skill_name",
    "order",
    "lane",
    "business_question",
    "entry",
    "outputs",
    "exit_criteria",
    "transition_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "deck_stage_contract.v1"
    },
    "stage_id": {
      "enum": [
        "deck-init",
        "deck-brief",
        "deck-planner",
        "deck-sourcing",
        "deck-producer",
        "deck-builder",
        "deck-quality",
        "deck-review",
        "deck-learn"
      ]
    },
    "skill_name": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "lane": {
      "enum": [
        "production",
        "post_delivery"
      ]
    },
    "business_question": {
      "type": "string",
      "minLength": 1
    },
    "allowed_previous_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entry": {
      "$ref": "#/$defs/validationRuleSet"
    },
    "first_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forcing_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactRequirement"
      }
    },
    "exit_criteria": {
      "$ref": "#/$defs/validationRuleSet"
    },
    "transition_policy": {
      "type": "object",
      "required": [
        "next_stage",
        "mode",
        "approval_required"
      ],
      "properties": {
        "next_stage": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "enum": [
            "automatic",
            "manual",
            "optional"
          ]
        },
        "approval_required": {
          "type": "boolean"
        },
        "preauthorizable": {
          "type": "boolean"
        },
        "non_bypassable": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "staleness_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "validationRuleSet": {
      "type": "object",
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "required": [
        "question_id",
        "category",
        "prompt",
        "required"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "assumption_allowed": {
          "type": "boolean"
        },
        "evidence_required": {
          "type": "boolean"
        },
        "trigger": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifactRequirement": {
      "type": "object",
      "required": [
        "artifact_type",
        "path_pattern",
        "required"
      ],
      "properties": {
        "artifact_type": {
          "type": "string"
        },
        "path_pattern": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "schema_version": {
          "type": "string"
        },
        "validator": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
