{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/generation-result.v1.schema.json",
  "title": "PPT Deck Pro Max Generation Result v1",
  "type": "object",
  "required": ["schema_version", "run_id", "session_id", "task_id", "status"],
  "properties": {
    "schema_version": {"const": "ppt_deck_pro_max_generation_result.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "tool": {"type": "string"},
    "task_id": {"type": "string", "minLength": 1},
    "beat_id": {"type": "string"},
    "page_id": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "failed", "success", "error"]
    },
    "artifact_path": {"type": "string"},
    "preview_path": {"type": "string"},
    "outputs": {
      "type": "object",
      "properties": {
        "artifact_path": {"type": "string"},
        "preview_path": {"type": "string"}
      },
      "additionalProperties": true
    },
    "artifact": {
      "type": "object",
      "properties": {
        "path": {"type": "string"},
        "type": {"type": "string"}
      },
      "additionalProperties": true
    },
    "preview": {
      "type": "object",
      "properties": {
        "path": {"type": "string"}
      },
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {"type": "object"}
    }
  },
  "anyOf": [
    {"required": ["beat_id"]},
    {"required": ["page_id"]}
  ],
  "additionalProperties": true
}
