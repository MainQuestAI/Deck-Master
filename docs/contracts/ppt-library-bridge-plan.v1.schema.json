{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/ppt-library-bridge-plan.v1.schema.json",
  "title": "Deck Master PPT Library Bridge Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "run_mode", "requests", "warnings"],
  "properties": {
    "schema_version": {"const": "deck_master_ppt_library_bridge_plan.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "run_mode": {"enum": ["production", "benchmark", "dev", "fixture", "preview", "interactive"]},
    "requests": {
      "type": "array",
      "items": {"$ref": "#/$defs/request"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beat_id",
        "page_task_id",
        "section_id",
        "order",
        "role_original",
        "role_strategy",
        "role_mapped",
        "query",
        "query_trace_id",
        "reuse_policy",
        "fallback_reason"
      ],
      "properties": {
        "beat_id": {"$ref": "#/$defs/identifier"},
        "page_task_id": {"$ref": "#/$defs/identifier"},
        "section_id": {"type": "string"},
        "order": {"type": "integer", "minimum": 1},
        "role_original": {"type": "string"},
        "role_strategy": {"enum": ["passthrough", "mapped", "semantic_only"]},
        "role_mapped": {
          "type": ["string", "null"],
          "enum": ["opener", "problem", "solution", "architecture", "case", "roi", "cta", "appendix", null]
        },
        "query": {"type": "string"},
        "query_trace_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "reuse_policy": {"enum": ["reuse", "adapt", "adapt_only", "reuse_or_adapt"]},
        "fallback_reason": {"type": "string"}
      }
    }
  }
}
