{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/library-status.v2.schema.json",
  "title": "Deck Master Library Status v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "runtime_ready",
    "contract_ready",
    "semantic_search_ready",
    "role_selection_ready",
    "fallback_ready",
    "preview_ready",
    "business_ranking_ready",
    "data_hygiene_status",
    "blocking_summary",
    "warnings"
  ],
  "properties": {
    "schema_version": {"const": "deck_master_library_status.v2"},
    "status": {"enum": ["ready", "degraded_ready", "blocked"]},
    "runtime_ready": {"type": "boolean"},
    "contract_ready": {"type": "boolean"},
    "semantic_search_ready": {"type": "boolean"},
    "role_selection_ready": {"type": "boolean"},
    "fallback_ready": {"type": "boolean"},
    "preview_ready": {"type": "boolean"},
    "business_ranking_ready": {"enum": ["ready", "cold_start", "blocked"]},
    "data_hygiene_status": {"enum": ["ready", "degraded", "blocked"]},
    "blocking_summary": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
