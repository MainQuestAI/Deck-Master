{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/sourcing-plan.v2.schema.json",
  "title": "Deck Sourcing Plan v2",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "status",
    "source_fingerprint",
    "pages",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "deck_sourcing_plan.v2"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "awaiting_approval",
        "approved",
        "blocked",
        "stale"
      ]
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pageDecision"
      }
    },
    "coverage": {
      "type": "object"
    },
    "approval_readiness": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "migrated_from": {
      "const": "deck_sourcing_plan.v1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "pageDecision": {
      "type": "object",
      "required": [
        "page_id",
        "page_task_id",
        "decision",
        "reason",
        "confidence",
        "evidence_need",
        "selected_sources",
        "permission_status"
      ],
      "properties": {
        "page_id": {
          "type": "string",
          "minLength": 1
        },
        "page_task_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "enum": [
            "reuse",
            "adapt",
            "generate",
            "evidence",
            "manual",
            "blocked"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_need": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/selectedSource"
          }
        },
        "source_authority": {
          "type": "string"
        },
        "freshness_status": {
          "type": "string"
        },
        "permission_status": {
          "enum": [
            "approved",
            "pending",
            "restricted",
            "blocked",
            "not_required"
          ]
        },
        "usage_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "production_budget_class": {
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": true
    },
    "selectedSource": {
      "type": "object",
      "required": [
        "asset_key",
        "query_trace_id",
        "page_task_id"
      ],
      "properties": {
        "candidate_id": {"type": "string"},
        "slide_id": {"type": ["string", "null"]},
        "asset_key": {"type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$"},
        "query_trace_id": {"type": "string", "minLength": 1},
        "page_task_id": {"type": "string", "minLength": 1},
        "title": {"type": "string"},
        "text_summary": {"type": "string"},
        "page_number": {"type": ["integer", "string", "null"]},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source_asset_id": {"type": "string"},
        "source_display_name": {"type": "string"},
        "screenshot_ref": {
          "type": "string",
          "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))(?:$|preview_assets/[A-Za-z0-9._/-]+)$"
        },
        "candidate_origin": {"enum": ["ppt_library", "fixture", "imported"]},
        "reuse_policy": {"enum": ["reuse", "adapt", "adapt_only", "reuse_or_adapt"]},
        "slot_id": {"type": "string"},
        "screenshot_path": {
          "type": "string",
          "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))preview_assets/[A-Za-z0-9._/-]+$"
        },
        "win_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "reuse_count": {"type": "integer", "minimum": 0},
        "source_authority": {"type": "string"},
        "freshness_status": {"type": "string"},
        "permission_status": {
          "enum": ["approved", "pending", "restricted", "blocked", "not_required"]
        },
        "reuse_safe": {"type": "boolean"},
        "usage_constraints": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
