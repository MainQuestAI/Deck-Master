{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deck Master Narrative Plan",
  "type": "object",
  "required": ["run_id", "title", "target_pages", "density", "beats"],
  "properties": {
    "run_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "target_pages": { "type": "integer", "minimum": 1 },
    "density": { "type": "string" },
    "industry": { "type": "string" },
    "audience": { "type": "string" },
    "gaps": { "type": "array" },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_id", "order", "page_title", "role", "content_goal", "reuse_query", "generation_brief"],
        "properties": {
          "beat_id": { "type": "string", "minLength": 1 },
          "order": { "type": "integer" },
          "page_title": { "type": "string" },
          "role": { "type": "string" },
          "brief": { "type": "string" },
          "content_goal": { "type": "string" },
          "evidence_need": { "type": "string" },
          "visual_need": { "type": "string" },
          "density": { "type": "string" },
          "reuse_query": { "type": "string" },
          "generation_brief": { "type": "string" },
          "approval_required": { "type": "boolean" }
        }
      }
    }
  }
}
