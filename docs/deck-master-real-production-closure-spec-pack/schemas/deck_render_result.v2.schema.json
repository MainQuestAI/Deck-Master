{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck_render_result.v2.schema.json",
  "title": "Deck Render Result v2",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "build_id",
    "profile",
    "status",
    "source_fingerprint",
    "page_count",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "deck_render_result.v2"
    },
    "run_id": {
      "type": "string"
    },
    "build_id": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "failed"
      ]
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "page_count": {
      "type": "integer",
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "kind",
          "path",
          "media_type",
          "sha256",
          "bytes",
          "validation_status"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "page_html",
              "html_fragment",
              "page_svg",
              "page_png",
              "page_jpeg",
              "page_pptx",
              "deck_html",
              "deck_pdf",
              "deck_pptx",
              "asset_bundle",
              "quality_report",
              "source_snapshot"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "^(?:/|[A-Za-z]:\\\\)|(?:^|/)\\.\\.(?:/|$)"
            }
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "validation_status": {
            "type": "string",
            "enum": [
              "validated",
              "invalid",
              "unvalidated",
              "stale",
              "missing"
            ]
          },
          "editability": {
            "type": "string",
            "enum": [
              "native",
              "hybrid",
              "flat_image",
              "not_applicable",
              "unknown"
            ]
          },
          "page_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "renderer": {
      "type": "object",
      "required": [
        "capability",
        "version"
      ],
      "properties": {
        "capability": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "completed",
              "partial"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "artifacts"
        ],
        "properties": {
          "artifacts": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "errors": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ]
}
