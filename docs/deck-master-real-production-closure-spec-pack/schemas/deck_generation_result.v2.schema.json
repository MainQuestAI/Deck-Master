{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck_generation_result.v2.schema.json",
  "title": "Deck Master Generation Result v2",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "task_id",
    "page_id",
    "producer",
    "status",
    "source_fingerprint",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "deck_generation_result.v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "beat_id": {
      "type": "string"
    },
    "producer": {
      "type": "object",
      "required": [
        "capability",
        "version",
        "source_ref"
      ],
      "properties": {
        "capability": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "failed"
      ]
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "kind",
          "path",
          "media_type",
          "sha256",
          "bytes",
          "validation_status"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "page_html",
              "html_fragment",
              "page_svg",
              "page_png",
              "page_jpeg",
              "page_pptx",
              "deck_html",
              "deck_pdf",
              "deck_pptx",
              "asset_bundle",
              "quality_report",
              "source_snapshot"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "^(?:/|[A-Za-z]:\\\\)|(?:^|/)\\.\\.(?:/|$)"
            }
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "validation_status": {
            "type": "string",
            "enum": [
              "validated",
              "invalid",
              "unvalidated",
              "stale",
              "missing"
            ]
          },
          "editability": {
            "type": "string",
            "enum": [
              "native",
              "hybrid",
              "flat_image",
              "not_applicable",
              "unknown"
            ]
          },
          "page_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "preview": {
      "type": "object",
      "required": [
        "artifact_id",
        "kind",
        "path",
        "media_type",
        "sha256",
        "bytes",
        "validation_status"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "page_html",
            "html_fragment",
            "page_svg",
            "page_png",
            "page_jpeg",
            "page_pptx",
            "deck_html",
            "deck_pdf",
            "deck_pptx",
            "asset_bundle",
            "quality_report",
            "source_snapshot"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^(?:/|[A-Za-z]:\\\\)|(?:^|/)\\.\\.(?:/|$)"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "validated",
            "invalid",
            "unvalidated",
            "stale",
            "missing"
          ]
        },
        "editability": {
          "type": "string",
          "enum": [
            "native",
            "hybrid",
            "flat_image",
            "not_applicable",
            "unknown"
          ]
        },
        "page_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "completed",
              "partial"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "artifacts",
          "preview"
        ]
      },
      "else": {
        "properties": {
          "artifacts": {
            "type": "array"
          },
          "errors": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
