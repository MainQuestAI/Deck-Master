.DS_Store

# Local agent/tool state
.claude/settings.local.json
.gbrain-source
.zcode/

# Python/runtime artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Environment and secrets
.env
.env.*

# Build/cache outputs
dist/
build/
!scripts/build/
!scripts/build/**
*.egg-info/
node_modules/
.gstack/
rc_reports/
tests/_ap_*/

# Re-ignore bytecode caches under un-ignored source dirs (e.g. scripts/build/)
**/__pycache__/
